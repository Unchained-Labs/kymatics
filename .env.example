# Shared credentials
MISTRAL_API_KEY=replace-me

# Public host ports
POSTGRES_PORT=5432
REDIS_PORT=6379
OTTER_PORT=8080
LAVOIX_PORT=8090
SEAL_PORT=5173

# Otter runtime tuning
OTTER_MAX_ATTEMPTS=5
OTTER_WORKER_CONCURRENCY=2
OTTER_RUST_LOG=info
OTTER_CORS_ALLOWED_ORIGINS=*
OTTER_DEFAULT_WORKSPACE_SUBDIR=auto
OTTER_VIBE_MODEL=mistral-large-3
OTTER_VIBE_PROVIDER=mistral
# Optional extra env forwarded to vibe process (comma-separated KEY=VALUE pairs)
# OTTER_VIBE_EXTRA_ENV=KEY1=VALUE1,KEY2=VALUE2
OTTER_RUNTIME_ENABLED=true
OTTER_RUNTIME_DOCKER_SOCKET=unix:///var/run/docker.sock
OTTER_RUNTIME_NETWORK=kymatics_default
OTTER_RUNTIME_CONTAINER_PREFIX=otter-ws
OTTER_RUNTIME_IMAGE_PREFIX=otter/workspace
OTTER_RUNTIME_DEFAULT_HOST=http://localhost
OTTER_RUNTIME_MAX_LOG_LINES=2000

# Lavoix runtime tuning
LAVOIX_VOXTRAL_MODEL=voxtral-mini-latest
LAVOIX_VOXTRAL_TTS_MODEL=voxtral-tts-latest
LAVOIX_DEFAULT_STT_PROVIDER=mistral
LAVOIX_DEFAULT_TTS_PROVIDER=mistral

# Seal build/runtime defaults
VITE_OTTER_URL=/api
VITE_OTTER_PROXY_TARGET=http://localhost:8080
